rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Japan 2026 Posts — anyone can read, only authenticated users can write
    match /jp26_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Japan 2026 Comments — anyone can read, only authenticated users can write
    match /jp26_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.authorUid;
    }

    // Fallback — keep existing collections unrestricted
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
