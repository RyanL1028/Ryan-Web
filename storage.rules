rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Japan 2026 uploads
    match /jp26/{allPaths=**} {
      // Anyone can view media
      allow read: if true;

      // Only authenticated users can upload
      allow create: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
          || request.resource.contentType.matches('image/webp')
          || request.resource.contentType.matches('image/heic')
          || request.resource.contentType.matches('image/heif')
          || request.resource.contentType.matches('image/avif')
          || request.resource.contentType.matches('video/mp4')
          || request.resource.contentType.matches('video/quicktime')
          || request.resource.contentType.matches('video/webm')
        );

      // Authenticated users can delete their own uploads
      allow delete: if request.auth != null;
    }

    // Fallback — keep existing files unrestricted
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
